# Core auth
# IMPORTANT: if cookie contains '$', escape it as '$$' when using docker compose.
SUNO_COOKIE=

# Optional: set a workspace/project name when you want creates assigned there.
# Leave empty to let Suno use the account's default behavior.
SUNO_WORKSPACE=

# Optional: direct proxy for outbound Suno HTTP traffic in local Node.js runs
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost,host.docker.internal

# Optional: Docker-specific proxy. Use host.docker.internal when the proxy runs
# on the host machine.
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_ALL_PROXY=
DOCKER_NO_PROXY=127.0.0.1,localhost,host.docker.internal

# Optional: apt mirrors for Docker builds when Debian's default mirror is slow
APT_DEBIAN_MIRROR=
APT_SECURITY_MIRROR=

# Optional: captcha solver support
# Required for any automated captcha solving path.
TWOCAPTCHA_API_KEY=
# Solver preference:
# - auto: follow Suno /api/c/check result (recommended)
# - hcaptcha / turnstile: manual preference only; conflicting values are ignored
#   when Suno reports the other captcha version.
SUNO_CREATE_CAPTCHA_METHOD=auto
# Optional shared public proxy used by both this runtime and 2Captcha when
# exact public IP binding matters. Must be a public http(s) proxy reachable by
# 2Captcha. Do not use localhost or LAN-only addresses here.
SUNO_CREATE_CAPTCHA_SHARED_PROXY_URL=
# For captcha_version=1:
# - browser (default): browser page solves/submits the challenge in the same
#   authenticated context; this API can still help by returning click points
# - legacy: server tries to fetch an hCaptcha token through 2Captcha
SUNO_CREATE_HCAPTCHA_TOKEN_MODE=browser

# Optional: override create metadata tier. If empty, runtime reads
# /api/billing/info and caches the returned tier.
SUNO_CREATE_USER_TIER=

# Optional: override the page URL used in captcha solver tasks.
SUNO_CREATE_CAPTCHA_PAGEURL=https://suno.com/create

# Optional: override sitekeys when Suno upstream changes them.
SUNO_CREATE_TURNSTILE_SITEKEY=0x4AAAAAADI7xDNyj-3LcIbi
SUNO_CREATE_HCAPTCHA_SITEKEY=d65453de-3f1a-4aac-9366-a0f06e52b2ce

# Optional: advanced challenge parameters. Only set these when you know the
# exact upstream values that must be mirrored for the current challenge shape.
SUNO_CREATE_HCAPTCHA_RQDATA=
SUNO_CREATE_HCAPTCHA_API_DOMAIN=
SUNO_CREATE_CAPTCHA_ACTION=
SUNO_CREATE_CAPTCHA_CDATA=
SUNO_CREATE_CAPTCHA_PAGEDATA=

# Optional: output root for final_song.json and generated metadata
SUNO_OUTPUT_DIR=/app/output

# Optional: output timestamp timezone
SUNO_OUTPUT_TIMEZONE=Asia/Shanghai

# Optional: exposed port for docker-compose.yml
SUNO_API_PORT=3000
